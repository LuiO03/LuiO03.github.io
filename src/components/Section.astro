---
interface Props {
	title?: string;
	description?: string;
}

const { title, description } = Astro.props;

import "../styles/components/section.css";
---

<section class="section">
	<div class="section-header">
		<h1>{title}</h1>
		<h6>{description}</h6>
	</div>
    <div class="section-content">
        <slot />
    </div>
</section>
